# 복사해서 .env 로 쓰고 키를 채우세요. 실행: uvicorn app.main:app --reload --env-file .env

# 기본 프로바이더 (mock | openai | replicate). 요청별 provider 필드로 override 가능.
PETFIT_PROVIDER=mock

# OpenAI gpt-image-2 (2026-04 출시)
PETFIT_OPENAI_API_KEY=
PETFIT_OPENAI_MODEL=gpt-image-2
PETFIT_OPENAI_SIZE=1024x1024

# Replicate (LoRA 파인튜닝을 쓰려면 오픈웨이트 dev 버전이어야 함 — pro 는 LoRA 불가)
PETFIT_REPLICATE_TOKEN=
PETFIT_REPLICATE_MODEL=black-forest-labs/flux-kontext-dev
# 감성 룩 → 학습된 LoRA 모델 매핑(JSON). 등록 안 하면 프롬프트로 폴백.
# 예: PETFIT_LOOK_MODELS={"winter": "ljo1010/pawdy-winter:abc123"}
PETFIT_LOOK_MODELS=
PETFIT_LOOK_TRIGGERS=
# LoRA 학습 트레이너(scripts/train_lora.py). Kontext 편집 LoRA 면 kontext 트레이너로 교체.
PETFIT_REPLICATE_TRAINER=replicate/fast-flux-trainer:latest

# CORS (프론트 origin)
PETFIT_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
