# 복사해서 .env 로 쓰고 키를 채우세요. 실행: uvicorn app.main:app --reload --env-file .env

# 기본 프로바이더 (mock | openai | replicate). 요청별 provider 필드로 override 가능.
PETFIT_PROVIDER=mock

# OpenAI gpt-image-2 (2026-04 출시)
PETFIT_OPENAI_API_KEY=
PETFIT_OPENAI_MODEL=gpt-image-2
PETFIT_OPENAI_SIZE=1024x1024

# Replicate
PETFIT_REPLICATE_TOKEN=
PETFIT_REPLICATE_MODEL=black-forest-labs/flux-kontext-pro

# CORS (프론트 origin)
PETFIT_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
